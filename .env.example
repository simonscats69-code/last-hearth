# Конфигурация окружения для Last Hearth

# Порт сервера (для Bothost обычно 3000)
PORT=3000

# Подключение к PostgreSQL (Supabase)
# Используй либо DATABASE_URL (строка подключения), либо отдельные параметры ниже
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.eddqhtpbpqzdixejmked.supabase.co:5432/postgres

# Отдельные параметры (если не используешь DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=last_hearth
DB_USER=postgres
DB_PASSWORD=your_password_here

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# URL Mini App (для webhook)
# Для Bothost: https://ваш-проект.bothost.ru
MINI_APP_URL=https://your-domain.com

# URL сервера для webhook
# Для Bothost: https://ваш-проект.bothost.ru/webhook
WEBHOOK_URL=https://your-domain.com/webhook

# AdsGram App ID
ADSGRAM_APP_ID=your_adsgram_app_id

# Секретный ключ для подписи данных
SECRET_KEY=your_secret_key_here
