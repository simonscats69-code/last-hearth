# Конфигурация окружения для Last Hearth

# Порт сервера (для Bothost обычно 3000)
PORT=3000

# Подключение к PostgreSQL
# Используйте DATABASE_URL (строка подключения из Supabase)
# Формат: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@host.supabase.co:5432/postgres

# Настройки пула БД
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000
DB_SSL=false

# Telegram Bot Token
TG_BOT_TOKEN=your_bot_token_here

# ID администраторов (через запятую)
ADMIN_IDS=

# URL Mini App (для webhook)
MINI_APP_URL=https://your-app.bothost.ru

# URL сервера для webhook
WEBHOOK_URL=https://your-app.bothost.ru/webhook

# Frontend URL для CORS
FRONTEND_URL=https://your-app.bothost.ru

# Максимальный возраст initData в секундах (по умолчанию 48 часов)
MAX_INIT_DATA_AGE_SECONDS=172800

# Режим разработки
DEV_MODE=false

# WebSocket
WS_TOKEN_SECRET=your_ws_secret_here
WS_REQUIRE_TOKEN=false

# Уровень логирования (error, warn, info, debug)
LOG_LEVEL=info

# AdsGram App ID
ADSGRAM_APP_ID=your_adsgram_app_id

# Секретный ключ для подписи данных
SECRET_KEY=your_secret_key_here