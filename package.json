{
  "name": "last-hearth",
  "version": "1.0.4",
  "description": "Постапокалиптический survival RPG Telegram Mini App",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"console.log('No build step required')\"",
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "jest",
    "migrate": "node db/database.js",
    "prod": "node db/database.js && node index.js",
    "postinstall": "node -e \"const fs=require('fs'); const p='public/game.js'; if(fs.existsSync(p)){fs.unlinkSync(p); console.log('Удалён старый файл game.js');}\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "pg": "^8.11.3",
    "node-telegram-bot-api": "^0.64.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "telegraf": "^4.15.3",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0"
  }
}
